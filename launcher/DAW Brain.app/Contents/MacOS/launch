#!/bin/bash
# DAW Brain — Electron App Launcher
# Launches the Electron desktop app from the repo's desktop/ directory,
# resolved relative to this bundle so the repo can live anywhere.

# macOS .app bundles get a minimal PATH — add common install locations
export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

# This script lives at <repo>/launcher/DAW Brain.app/Contents/MacOS/launch
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
APP_DIR="$REPO_ROOT/desktop"
ELECTRON="$APP_DIR/node_modules/.bin/electron"

cd "$APP_DIR"
exec "$ELECTRON" .
