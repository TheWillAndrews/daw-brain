#!/bin/bash
# DAW Brain — Electron App Launcher
# Launches the Electron desktop app from the daw-brain-app directory.

# macOS .app bundles get a minimal PATH — add common install locations
export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

APP_DIR="$HOME/Desktop/TRK_TOOLS/daw-brain-app"
ELECTRON="$APP_DIR/node_modules/.bin/electron"

cd "$APP_DIR"
exec "$ELECTRON" .
